<Window x:Class="FsocietyCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fsociety Cleaner"
        Height="580" Width="780"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>

        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7AAACC"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A66AA"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3AAAEE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#2A88CC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slim flat ProgressBar -->
        <Style x:Key="SlimBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="Foreground" Value="#3AAAEE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border CornerRadius="6" BorderBrush="#3399DD" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#000000" Offset="0"/>
                <GradientStop Color="#001530" Offset="0.5"/>
                <GradientStop Color="#005599" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#55000000" CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Fsociety Cleaner"
                               Foreground="#CCDDEE" FontFamily="Segoe UI"
                               FontSize="12" VerticalAlignment="Center" Margin="12,0"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="—" Style="{StaticResource WinBtn}" Click="Minimize_Click"/>
                        <Button Content="✕" Style="{StaticResource WinBtn}" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tabs -->
            <Border Grid.Row="1" Background="#33000000"
                    BorderBrush="#225577" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="TabHome"    Content="Home"
                            Style="{StaticResource TabBtn}" Click="TabHome_Click"/>
                    <Button x:Name="TabSpoof"   Content="Spoof"
                            Style="{StaticResource TabBtn}" Click="TabSpoof_Click"/>
                    <Button x:Name="TabClean"   Content="Clean"
                            Style="{StaticResource TabBtn}" Click="TabClean_Click"/>
                    <Button x:Name="TabSerials" Content="System Info"
                            Style="{StaticResource TabBtn}" Click="TabSerials_Click"/>
                    <Button x:Name="TabRestore" Content="Create Restore Point"
                            Style="{StaticResource TabBtn}" Click="TabRestore_Click"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="2">

                <!-- HOME -->
                <Grid x:Name="PageHome">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40,20">
                        <TextBlock Text="TEMP SPOOFER"
                                   Foreground="#80CFFF" FontSize="13"
                                   FontFamily="Segoe UI" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,2">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00CFFF" BlurRadius="14" ShadowDepth="0" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Fsociety Cleaner"
                                   Foreground="White" FontSize="34"
                                   FontFamily="Segoe UI" FontWeight="Light"
                                   HorizontalAlignment="Center"/>

                        <Rectangle Height="1" Width="240" Fill="#3399DD" Opacity="0.4" Margin="0,12,0,14"/>

                        <TextBlock Text="Temp Spoofer and Cleaner"
                                   Foreground="#CCDDEE" FontSize="13"
                                   FontFamily="Segoe UI" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="#AACCDD" FontSize="12"
                                   FontFamily="Segoe UI" LineHeight="20"
                                   MaxWidth="560"
                                   HorizontalAlignment="Center" Margin="0,0,0,8">
                            Spoof your hardware identifiers and wipe every trace of Epic Games
                            and Fortnite from your system in a single click.
                        </TextBlock>

                        <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="#88AAC0" FontSize="11"
                                   FontFamily="Segoe UI" LineHeight="18"
                                   MaxWidth="560"
                                   HorizontalAlignment="Center" Margin="0,0,0,18">
                            Generates a fresh hardware fingerprint, terminates running processes,
                            removes registry traces, deletes leftover folders and flushes the DNS cache —
                            giving you a fully clean slate to start over.
                        </TextBlock>

                        <TextBlock Text="Pick a tab above to get started."
                                   Foreground="#6688AA" FontSize="11"
                                   FontFamily="Segoe UI" FontStyle="Italic"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- CLEAN -->
                <Grid x:Name="PageClean" Visibility="Collapsed">
                    <Grid Margin="22,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,4,0,14">
                            <Button x:Name="btnFN" Content="Run Cleaner"
                                    Style="{StaticResource ActionBtn}"
                                    Click="RunFNCleaner_Click"/>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#225577" BorderThickness="1"
                                Background="#22000000" CornerRadius="3">
                            <ScrollViewer x:Name="cleanScroll"
                                          VerticalScrollBarVisibility="Auto" Margin="2">
                                <TextBox x:Name="cleanLog" Background="Transparent"
                                         Foreground="#AADDEE" FontFamily="Consolas" FontSize="11"
                                         IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0"
                                         Padding="8,6"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- SPOOF -->
                <Grid x:Name="PageSpoof" Visibility="Collapsed">
                    <Grid Margin="22,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,4,0,10">
                            <Button x:Name="btnSpoof" Content="Start Spoof"
                                    Style="{StaticResource ActionBtn}"
                                    Click="RunSpoof_Click"/>
                        </StackPanel>

                        <ProgressBar Grid.Row="1" x:Name="spoofProgress"
                                     Style="{StaticResource SlimBar}"
                                     Maximum="100" Minimum="0" Value="0"
                                     Visibility="Hidden" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="2" x:Name="spoofStatus" Text=""
                                   Foreground="#80CFFF" FontFamily="Segoe UI"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <!-- Before/After comparison panel -->
                        <Border Grid.Row="3" x:Name="spoofComparison"
                                BorderBrush="#225577" BorderThickness="1"
                                Background="#22000000" CornerRadius="3"
                                Padding="14,10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Headers -->
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="BEFORE"
                                           Foreground="#7799AA" FontFamily="Segoe UI"
                                           FontSize="10" FontWeight="Bold"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="AFTER (SPOOFED)"
                                           Foreground="#00CFFF" FontFamily="Segoe UI"
                                           FontSize="10" FontWeight="Bold"/>

                                <!-- UUID -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Machine UUID"
                                           Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="beforeUuid" Text="—"
                                           Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="→"
                                           Foreground="#00CFFF" FontFamily="Segoe UI"
                                           FontSize="12" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="3" x:Name="afterUuid" Text="—"
                                           Foreground="#00CFFF" FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- BIOS -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="BIOS Serial"
                                           Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="beforeBios" Text="—"
                                           Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="→"
                                           Foreground="#00CFFF" FontFamily="Segoe UI"
                                           FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="3" x:Name="afterBios" Text="—"
                                           Foreground="#00CFFF" FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>

                                <!-- Disk -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Disk Serial"
                                           Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="beforeDisk" Text="—"
                                           Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="→"
                                           Foreground="#00CFFF" FontFamily="Segoe UI"
                                           FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="3" x:Name="afterDisk" Text="—"
                                           Foreground="#00CFFF" FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>

                                <!-- MAC -->
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="MAC Address"
                                           Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="beforeMac" Text="—"
                                           Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="5" Grid.Column="2" Text="→"
                                           Foreground="#00CFFF" FontFamily="Segoe UI"
                                           FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="5" Grid.Column="3" x:Name="afterMac" Text="—"
                                           Foreground="#00CFFF" FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>

                                <!-- Motherboard -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Motherboard SN"
                                           Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="beforeMobo" Text="—"
                                           Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="→"
                                           Foreground="#00CFFF" FontFamily="Segoe UI"
                                           FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="6" Grid.Column="3" x:Name="afterMobo" Text="—"
                                           Foreground="#00CFFF" FontFamily="Consolas" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4" BorderBrush="#225577" BorderThickness="1"
                                Background="#22000000" CornerRadius="3">
                            <ScrollViewer x:Name="spoofScroll"
                                          VerticalScrollBarVisibility="Auto" Margin="2">
                                <TextBox x:Name="spoofLog" Background="Transparent"
                                         Foreground="#AADDEE" FontFamily="Consolas" FontSize="11"
                                         IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0"
                                         Padding="8,6"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- SYSTEM INFO -->
                <Grid x:Name="PageSerials" Visibility="Collapsed">
                    <Grid Margin="22,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,4,0,12">
                            <Button x:Name="btnSerials" Content="Refresh"
                                    Style="{StaticResource ActionBtn}"
                                    Click="SerialsCheck_Click"/>
                            <Button x:Name="btnCopyInfo" Content="Copy to Clipboard"
                                    Style="{StaticResource ActionBtn}"
                                    Margin="10,0,0,0"
                                    Click="CopyInfo_Click"/>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#225577" BorderThickness="1"
                                Background="#22000000" CornerRadius="3">
                            <ScrollViewer x:Name="serialsScroll"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="4">
                                <Grid Margin="14,12,14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="── SYSTEM ──"
                                               Foreground="#00CFFF" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="Bold" Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Operating System"
                                               Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="infoOs" Text="—"
                                               Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Machine Name"
                                               Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="infoMachine" Text="—"
                                               Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11" Margin="0,3,0,0"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="User Name"
                                               Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="infoUser" Text="—"
                                               Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11" Margin="0,3,0,0"/>

                                    <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Text="── HARDWARE ──"
                                               Foreground="#00CFFF" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="Bold" Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="CPU"
                                               Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="infoCpu" Text="—"
                                               Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="RAM (Total)"
                                               Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" x:Name="infoRam" Text="—"
                                               Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11" Margin="0,3,0,0"/>

                                    <TextBlock Grid.Row="9" Grid.ColumnSpan="2" Text="── FIRMWARE / BOARD ──"
                                               Foreground="#00CFFF" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="Bold" Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Machine UUID"
                                               Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11"/>
                                    <TextBlock Grid.Row="10" Grid.Column="1" x:Name="infoUuid" Text="—"
                                               Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="11" Grid.Column="0" Text="BIOS Vendor"
                                               Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="11" Grid.Column="1" x:Name="infoBiosVendor" Text="—"
                                               Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11" Margin="0,3,0,0"/>

                                    <TextBlock Grid.Row="12" Grid.Column="0" Text="BIOS Serial"
                                               Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="12" Grid.Column="1" x:Name="infoBiosSerial" Text="—"
                                               Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11" Margin="0,3,0,0"/>

                                    <TextBlock Grid.Row="13" Grid.Column="0" Text="Motherboard"
                                               Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="13" Grid.Column="1" x:Name="infoMobo" Text="—"
                                               Foreground="#CCDDEE" FontFamily="Consolas" FontSize="11" Margin="0,3,0,0"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="15" Grid.ColumnSpan="2" Text="── STORAGE / NETWORK ──"
                                               Foreground="#00CFFF" FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="Bold" Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="16" Grid.Column="0" Text="Disk Serial(s)"
                                               Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11"
                                               VerticalAlignment="Top"/>
                                    <StackPanel Grid.Row="16" Grid.Column="1" x:Name="infoDisks"/>

                                    <TextBlock Grid.Row="17" Grid.Column="0" Text="MAC Address(es)"
                                               Foreground="#7799AA" FontFamily="Segoe UI" FontSize="11"
                                               VerticalAlignment="Top" Margin="0,6,0,0"/>
                                    <StackPanel Grid.Row="17" Grid.Column="1" x:Name="infoMacs" Margin="0,6,0,0"/>
                                </Grid>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- RESTORE -->
                <Grid x:Name="PageRestore" Visibility="Collapsed">
                    <Grid Margin="22,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,4,0,14">
                            <Button x:Name="btnRestore" Content="Create Restore Point"
                                    Style="{StaticResource ActionBtn}"
                                    Click="CreateRestorePoint_Click"/>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#225577" BorderThickness="1"
                                Background="#22000000" CornerRadius="3">
                            <ScrollViewer x:Name="restoreScroll"
                                          VerticalScrollBarVisibility="Auto" Margin="2">
                                <TextBox x:Name="restoreLog" Background="Transparent"
                                         Foreground="#AADDEE" FontFamily="Consolas" FontSize="11"
                                         IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0"
                                         Padding="8,6"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
